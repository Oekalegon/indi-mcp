[Unit]
Description=INDI MCP server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=indi-mcp
Group=indi-mcp
SupplementaryGroups=dialout
WorkingDirectory=/opt/indi-mcp
# Built-in scripts ship in the repo checkout (src/scripts), not WorkingDirectory — without
# this, script_store's default `./scripts` lookup would resolve to /opt/indi-mcp/scripts
# instead and silently find nothing.
Environment=INDI_MCP_SCRIPTS_DIR=/opt/indi-mcp/src/scripts
ExecStart=/opt/indi-mcp/.venv/bin/indi-mcp --transport streamable-http --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

# Hardening (loosen if it breaks USB/serial or INDI-driver process access)
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths=/opt/indi-mcp

[Install]
WantedBy=multi-user.target
